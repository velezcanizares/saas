# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL='http://localhost:3000'
# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL='http://localhost:3000'
NEXTAUTH_SECRET='1'

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='1'
CLERK_SECRET_KEY='1'

GITHUB_CLIENT_ID='1'
GITHUB_CLIENT_SECRET='1'

# -----------------------------------------------------------------------------
# Email (RESEND)
# -----------------------------------------------------------------------------
RESEND_API_KEY='1'
RESEND_FROM='1'

# -----------------------------------------------------------------------------
# Suscripción del SaaS (Stripe) — lo que le cobras al dueño de la pyme.
# -----------------------------------------------------------------------------
# 1) Panel de Stripe > Developers > API keys. Usa la Secret key (sk_...).
STRIPE_API_KEY="sk_test_..."
# 2) Panel de Stripe > Developers > Webhooks. Crea un endpoint que apunte a
#    <tu-dominio>/api/webhooks/stripe y copia el "Signing secret" (whsec_...).
STRIPE_WEBHOOK_SECRET="whsec_..."
#
# 3) Crea en Stripe (Products) los planes CON PRECIOS EN CLP y pega los IDs.
#    Debe coincidir con los montos de packages/common/src/subscriptions.ts:
#      Pro:      $14.990/mes  ·  $149.900/año
#      Business: $29.990/mes  ·  $299.900/año
#    Cada precio recurrente que creas en Stripe genera un price_... : pégalos aquí.
NEXT_PUBLIC_STRIPE_PRO_PRODUCT_ID="prod_"
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID="price_"     # Pro mensual (CLP 14990)
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID="price_"      # Pro anual  (CLP 149900)
NEXT_PUBLIC_STRIPE_BUSINESS_PRODUCT_ID="prod_"
NEXT_PUBLIC_STRIPE_BUSINESS_MONTHLY_PRICE_ID="price_" # Business mensual (CLP 29990)
NEXT_PUBLIC_STRIPE_BUSINESS_YEARLY_PRICE_ID="price_"  # Business anual  (CLP 299900)

# -----------------------------------------------------------------------------
# Pago del cliente final en el POS (Mercado Pago) — que el cliente pague la venta.
# -----------------------------------------------------------------------------
# Panel de Mercado Pago > Tus integraciones > crea una aplicación > Credenciales.
# Pega el Access Token (de PRODUCCIÓN o de PRUEBA). Con esto se generan los
# checkouts. Déjalo vacío para desactivar el cobro con Mercado Pago.
# Además, en el panel de Mercado Pago configura la URL de notificaciones (webhook)
# apuntando a <tu-dominio>/api/webhooks/mercadopago (evento: payment).
MERCADO_PAGO_ACCESS_TOKEN=""

# posthog
NEXT_PUBLIC_POSTHOG_KEY=" "
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# admin account
ADMIN_EMAIL="admin@saasfly.io,root@saasfly.io"

# next auth debug
IS_DEBUG=false